# --- Backend configuration (copy to backend/.env and fill in) ---

# MongoDB connection string and database name
MONGO_URL="mongodb://localhost:27017"
DB_NAME="word_up_db"

# REQUIRED in production: a long, random, secret string used to sign JWTs.
# Generate one with:  python -c "import secrets; print(secrets.token_urlsafe(48))"
JWT_SECRET="change-me-to-a-long-random-secret"
JWT_ALGORITHM="HS256"
JWT_EXPIRATION_DAYS=7

# "development" or "production". Production enforces a strong JWT_SECRET,
# forces Secure cookies, hides API docs, and sends HSTS headers.
ENVIRONMENT="development"

# Comma-separated list of allowed frontend origins for credentialed CORS,
# e.g. "https://your-frontend.example.com". When unset, local dev origins
# (http://localhost:3000, http://127.0.0.1:3000) are allowed. REQUIRED in
# production so the deployed frontend can make authenticated requests.
CORS_ORIGINS=""

# Optional: external OAuth session-exchange endpoint. Leave empty to disable
# third-party (e.g. Google) sign-in entirely.
OAUTH_SESSION_URL=""
